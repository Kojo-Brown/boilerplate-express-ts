# ── App ───────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── JWT (generate with: openssl rand -hex 32) ─────────────────────────────────
JWT_ACCESS_SECRET=replace-with-openssl-rand-hex-32-output
JWT_REFRESH_SECRET=replace-with-a-different-openssl-rand-hex-32-output
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=replace-with-openssl-rand-hex-32-output

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=boilerplate
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:replace-with-a-strong-password@localhost:5432/boilerplate

# ── OAuth (Google) ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/v1/auth/oauth/google/callback

# ── AWS / S3 ──────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_BUCKET=your-s3-bucket-name
S3_PRESIGNED_EXPIRES_IN=3600
